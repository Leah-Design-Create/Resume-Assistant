# 阿里云百炼 DashScope API Key（后端聊天接口必填）
# 获取：https://bailian.console.aliyun.com/#/api-key
DASHSCOPE_API_KEY="sk-xxx"

# 通义千问文本模型（必填）
# 可选：qwen-turbo、qwen-plus、qwen-max
DASHSCOPE_MODEL=qwen-plus

# 通义千问视觉模型（上传 PDF 时识别人脸/证件照裁剪为头像，可选，默认 qwen-vl-max）
# 可选：qwen-vl-max、qwen-vl-plus（Qwen2.5-VL）、qwen3-vl-plus、qwen3-vl-flash（Qwen3-VL）
# DASHSCOPE_VL_MODEL=qwen-vl-max

# 后端服务端口，默认 3001
# PORT=3001

# 前端地址，用于 CORS，开发时默认 http://localhost:3000
# FRONTEND_ORIGIN=http://localhost:3000

# APP_URL: 应用部署地址（可选）
# APP_URL="MY_APP_URL"
